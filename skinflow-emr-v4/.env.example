# Django settings
DJANGO_SECRET_KEY=changeme-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS configuration
DJANGO_CORS_ALLOW_ALL_ORIGINS=True
DJANGO_CORS_ALLOW_CREDENTIALS=True

# Database configuration
# Defaults to SQLite for local development. For PostgreSQL, for example:
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=skinflow
# DJANGO_DB_USER=skinflow
# DJANGO_DB_PASSWORD=changeme
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=5432
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=

# API keys
SKINFLOW_API_KEY=dev-key-12345
PHARMASEED_API_KEY=

